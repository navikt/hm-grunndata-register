DB_DRIVER=org.postgresql.Driver
DB_JDBC_URL=jdbc:postgresql://localhost:5432/register
RAPIDSANDRIVERS_ENABLED=true
SCHEDULERS_ENABLED=true
SERVER_PORT=8080
KAFKA_BROKERS=localhost:29092
MICRONAUT_SERVER_CORS_ENABLED=true
MICRONAUT_SERVER_CORS_CONFIGURATIONS_DEFAULT_ALLOWED_ORIGINS=http://localhost:5173
MICRONAUT_SERVER_CORS_CONFIGURATIONS_DEFAULT_ALLOW_CREDENTIALS=true
MICRONAUT_SERVER_CORS_CONFIGURATIONS_DEFAULT_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
MICRONAUT_SERVER_CORS_CONFIGURATIONS_DEFAULT_ALLOWED_HEADERS=Content-Type,Authorization
JDK_JAVA_OPTIONS="-Dlogback.configurationFile=src/test/resources/logback-test.xml"